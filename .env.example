# ── executor ──────────────────────────────────────────────────────────────────
# Base58 secret key. Needs devnet SOL (order rent ~0.003/order) — NO mainnet funds required.
PRIVATE_KEY=

# Mainnet RPC used to verify Flash session tokens (the /session check). MUST
# include https:// and MUST be a SERVER-SIDE key (a browser/domain-restricted
# key is rejected because the executor sends no Origin). Defaults to the public
# mainnet RPC, which rate-limits datacenter IPs — set your own for a real deploy.
# FLASH_BASE_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_BACKEND_KEY

# Optional overrides (defaults shown)
# GHOST_PROGRAM_ID=y8gjZcwDHqZ8Sz2Uziw5nxr2cWKGyAKaqtNAUJ2mKxh
# GHOST_BASE_RPC=https://api.devnet.solana.com
# GHOST_ER_RPC=https://devnet.magicblock.app
# EXECUTOR_PORT=8787
# EXECUTOR_CORS_ORIGIN=*

# ── apps/web (.env.local) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_EXECUTOR_URL=http://localhost:8787
# NEXT_PUBLIC_GHOST_PROGRAM=y8gjZcwDHqZ8Sz2Uziw5nxr2cWKGyAKaqtNAUJ2mKxh
# NEXT_PUBLIC_GHOST_ER_RPC=https://devnet.magicblock.app
# NEXT_PUBLIC_BASE_RPC=https://solana-rpc.publicnode.com   # default; or your own keyed RPC
